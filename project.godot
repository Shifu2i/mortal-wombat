; Engine configuration file.
;
; Godot 4 stable. Edits via the editor are fine, but the rollback-readiness
; rules (see CLAUDE.md) constrain physics, RNG, and tick behaviour.

config_version=5

[application]

config/name="Mortal Wombat"
config/description="2D platform fighter with Australian animals. Solo dev, Steam target."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.2", "GL Compatibility")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/size/window_width_override=1440
window/size/window_height_override=810
window/stretch/mode="viewport"
window/stretch/aspect="keep"
window/stretch/scale_mode="integer"

